---
import Layout from '../../layouts/Layout.astro';
import { getCollection, getEntry } from 'astro:content';
import ProductCard from '../ProductCard';
import { translations, type SupportedLanguage, cleanProductTitle, translatePackageSize, getLocalizedPath, translateCategorySlug } from '../../i18n/translations';
import { getMarket } from '../../i18n/market';

interface Props {
  lang: SupportedLanguage;
}

const { lang } = Astro.props;
const market = getMarket(lang);
const siteCopy = await getEntry('site', lang === 'en' ? 'en' : lang);
const siteData = siteCopy?.data;
const seoName = siteData?.seo?.homeName ?? `Peptide Shop - Buy Peptides ${market.marketName} & Europe`;
const seoDescription = siteData?.seo?.homeDescription ?? `Buy peptides ${market.marketName} & Europe. Premium research peptides for sale with 99% purity. Fast delivery, COA included. Semaglutide, BPC-157, Tirzepatide & more.`;
const organizationDescription = siteData?.seo?.organizationDescription ?? `Buy peptides ${market.marketName} & Europe. Leading supplier of research peptides with 99% purity. Fast delivery across ${market.geoPlacename} and Europe.`;

function t(key: string): string {
  const keys = key.split('.');
  let value: any = translations[lang];
  for (const k of keys) {
      if (value && typeof value === 'object' && k in value) {
          value = value[k];
      } else {
          return key;
      }
  }
  return typeof value === 'string' ? value : key;
}

// Helper to clean slug - removes language prefix and /peptides/ prefix
const cleanSlug = (slug: string) => {
  // Remove language prefix (e.g., 'en/', 'de/', 'nl/', 'ru/', etc.)
  const withoutLang = slug.replace(/^(en|de|nl|fr|es|it|ru)\//, '');
  // Remove /peptides/ prefix and leading slashes
  return withoutLang.replace(/^\/peptides\//, '').replace(/^\//, '');
};

// Helper function to strip language prefix from blog slugs
// Handles both folder prefixes (en/, ru/) and file prefixes (nl-, de-, fr-, es-, it-, ru-)
function stripLangPrefix(slug: string): string {
  return slug
    .replace(/^(en|nl|de|fr|es|it|ru)\//, '') // Strip folder prefix like "en/"
    .replace(/^(nl|de|fr|es|it|ru)-/, ''); // Strip all language file prefixes
}

// Fetch products for "Best Sellers" - filter by current language
const allProducts = await getCollection('products');
const featuredProducts = allProducts
  .filter(p => p.slug.startsWith(`${lang}/`))
  .slice(0, 8);

// Fetch recent blog posts
const allBlogPosts = await getCollection('blog');
const recentPosts = allBlogPosts
  .filter(p => p.data.lang === lang)
  .sort((a, b) => new Date(b.data.publishDate).valueOf() - new Date(a.data.publishDate).valueOf())
  .slice(0, 3);

// Fallback if no localized posts found for this language - use English posts with English paths
const displayPosts = recentPosts.length > 0 
  ? recentPosts.map(p => ({ ...p, useFallbackLang: false }))
  : allBlogPosts
      .filter(p => p.data.lang === 'en')
      .sort((a, b) => new Date(b.data.publishDate).valueOf() - new Date(a.data.publishDate).valueOf())
      .slice(0, 3)
      .map(p => ({ ...p, useFallbackLang: true }));

const categories = [
  { name: t('nav.weightLoss'), slug: 'weight-loss', localizedSlug: translateCategorySlug('weight-loss', lang), icon: 'scale', desc: t('home.categories.desc.weightLoss'), gradient: 'from-purple-500 to-pink-500' },
  { name: t('nav.muscleRecovery'), slug: 'muscle-recovery', localizedSlug: translateCategorySlug('muscle-recovery', lang), icon: 'activity', desc: t('home.categories.desc.muscleRecovery'), gradient: 'from-blue-500 to-cyan-500' },
  { name: t('nav.cognitive'), slug: 'cognitive', localizedSlug: translateCategorySlug('cognitive', lang), icon: 'brain', desc: t('home.categories.desc.cognitive'), gradient: 'from-green-500 to-emerald-500' },
  { name: t('nav.growthHormone'), slug: 'growth-hormone', localizedSlug: translateCategorySlug('growth-hormone', lang), icon: 'clock', desc: t('home.categories.desc.antiAging'), gradient: 'from-orange-500 to-red-500' },
];

// Helper to get category URL with translated slug
const getCategoryUrl = (category: string) => {
  if (lang === 'en') {
    return `/peptides/${category}/`;
  }
  const translatedSlug = translateCategorySlug(category, lang);
  return `/${lang}/peptides/${translatedSlug}/`;
};

const testimonials = [
  { name: 'Dr. Sarah Mitchell', role: t('home.testimonials.role1'), text: t('home.testimonials.text1'), rating: 5 },
  { name: 'Prof. James Chen', role: t('home.testimonials.role2'), text: t('home.testimonials.text2'), rating: 5 },
  { name: 'Dr. Emma Rodriguez', role: t('home.testimonials.role3'), text: t('home.testimonials.text3'), rating: 5 },
];

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": seoName,
  "description": seoDescription,
  "url": "https://peptide-shop.net",
  "inLanguage": ["en-GB", "nl-NL", "de-DE", "fr-FR", "es-ES", "it-IT", "ru-RU"],
  "potentialAction": {
    "@type": "SearchAction",
    "target": "https://peptide-shop.net/peptides?q={search_term_string}",
    "query-input": "required name=search_term_string"
  }
};

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Peptide Shop",
  "alternateName": `PeptideShop ${market.marketName}`,
  "url": "https://peptide-shop.net",
  "logo": "https://peptide-shop.net/favicon.png",
  "description": organizationDescription,
  "areaServed": [
    {"@type": "Country", "name": "United Kingdom"},
    {"@type": "Country", "name": "Netherlands"},
    {"@type": "Country", "name": "Germany"},
    {"@type": "Country", "name": "France"},
    {"@type": "Country", "name": "Spain"},
    {"@type": "Country", "name": "Italy"},
    {"@type": "Country", "name": "Belgium"},
    {"@type": "Country", "name": "Ireland"},
    {"@type": "Country", "name": "Austria"},
    {"@type": "Country", "name": "Portugal"},
    {"@type": "Country", "name": "Russia"}
  ],
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "customer service",
    "areaServed": ["GB", "NL", "DE", "FR", "ES", "IT", "RU"],
    "availableLanguage": ["English", "Dutch", "German", "French", "Spanish", "Italian", "Russian"]
  },
  "sameAs": [
    "https://t.me/Nebelzee"
  ]
};

const homeSchema = {
  "@context": "https://schema.org",
  "@graph": [
    websiteSchema,
    organizationSchema
  ]
};
---

<Layout 
  title={t('home.heroTitle') + ' | ' + t('home.heroTitleHighlight') + ' | Peptide Shop'}
  description={t('home.heroSubtitle')}
  schema={homeSchema}
>

  <!-- SHOPCART-INSPIRED E-COMMERCE STYLES -->
  <style is:global>
    :root {
      --shop-primary: #0077b6;
      --shop-primary-light: rgba(0, 119, 182, 0.1);
      --shop-secondary: #1e293b;
      --shop-accent: #f59e0b;
      --shop-bg: #ffffff;
      --shop-surface: #f9fafb;
      --shop-border: #e5e7eb;
      --shop-text: #1e293b;
      --shop-text-muted: #6b7280;
    }

    body {
      background-color: var(--shop-bg);
      color: var(--shop-text);
      font-family: 'Raleway', -apple-system, sans-serif;
      overflow-x: hidden;
    }

    /* Full-width sections - Avoid 100vw to prevent horizontal scrollbar */
    .full-width-section {
      width: 100%;
      position: relative;
      box-sizing: border-box;
    }

    .section-padding {
      padding: 80px 60px !important;
    }

    @media (max-width: 768px) {
      .section-padding {
        padding: 48px 28px !important;
      }
    }

    @media (max-width: 480px) {
      .section-padding {
        padding: 40px 24px !important;
      }
    }

    @media (max-width: 360px) {
      .section-padding {
        padding: 32px 20px !important;
      }
    }

    .inner-container {
      max-width: 1400px;
      margin: 0 auto;
      width: 100%;
      box-sizing: border-box;
    }

    /* Prevent horizontal overflow globally */
    img, svg, video, iframe, embed, object {
      max-width: 100%;
      height: auto;
    }

    /* Shopcart Hero Banner */
    .hero-banner {
      background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 50%, #d1fae5 100%);
      position: relative;
      overflow: hidden;
    }

    .hero-banner::before {
      content: '';
      position: absolute;
      top: -50%;
      right: -10%;
      width: 80%;
      height: 200%;
      background: radial-gradient(circle, rgba(0, 119, 182, 0.05) 0%, transparent 60%);
      border-radius: 50%;
    }

    .hero-content {
      position: relative;
      z-index: 2;
    }

    .hero-badge {
      display: inline-block;
      background: var(--shop-primary);
      color: white;
      padding: 8px 18px;
      border-radius: 24px;
      font-size: clamp(11px, 3vw, 13px);
      font-weight: 600;
      margin-bottom: 20px;
      max-width: 100%;
      word-break: break-word;
      box-sizing: border-box;
      line-height: 1.4;
    }

    .hero-title {
      font-size: clamp(24px, 7.5vw, 56px);
      font-weight: 800;
      color: var(--shop-secondary);
      line-height: 1.1;
      margin-bottom: 24px;
      word-break: break-word;
      overflow-wrap: break-word;
      hyphens: auto;
      letter-spacing: -0.02em;
    }

    .hero-subtitle {
      font-size: clamp(15px, 4vw, 18px);
      color: var(--shop-text-muted);
      max-width: min(520px, 100%);
      margin-bottom: 32px;
      line-height: 1.65;
    }

    .btn-shop-primary {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      background: var(--shop-primary);
      color: white;
      padding: 16px 32px;
      border-radius: 12px;
      font-weight: 600;
      font-size: 16px;
      text-decoration: none;
      transition: all 0.3s ease;
      border: none;
      cursor: pointer;
      min-height: 48px;
      box-sizing: border-box;
    }

    .btn-shop-primary:hover {
      background: #15503a;
      color: white;
      transform: translateY(-2px);
      box-shadow: 0 8px 20px rgba(0, 119, 182, 0.25);
    }

    .btn-shop-outline {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      background: transparent;
      color: var(--shop-secondary);
      padding: 16px 32px;
      border-radius: 12px;
      font-weight: 600;
      font-size: 16px;
      text-decoration: none;
      border: 2px solid var(--shop-border);
      transition: all 0.3s ease;
      cursor: pointer;
      min-height: 48px;
      box-sizing: border-box;
    }

    .btn-shop-outline:hover {
      border-color: var(--shop-primary);
      color: var(--shop-primary);
      background: var(--shop-primary-light);
    }

    /* Section Headers */
    .section-header {
      margin-bottom: 40px;
    }

    .section-label {
      font-size: 13px;
      font-weight: 600;
      color: var(--shop-primary);
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 8px;
    }

    .section-title {
      font-size: clamp(1.75rem, 4vw, 2.5rem);
      font-weight: 700;
      color: var(--shop-secondary);
      margin-bottom: 12px;
    }

    .section-desc {
      font-size: 1rem;
      color: var(--shop-text-muted);
      max-width: 600px;
    }

    /* Product Grid */
    .products-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 24px;
    }

    @media (max-width: 1200px) {
      .products-grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    @media (max-width: 992px) {
      .products-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 576px) {
      .products-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 12px;
      }
    }

    /* Category Cards - Shopcart Style - 4 columns */
    .category-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
    }

    @media (max-width: 1200px) {
      .category-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 576px) {
      .category-grid {
        grid-template-columns: 1fr;
      }
    }

    /* Hero Image Styles */
    .hero-image-wrapper {
      position: relative;
    }

    .hero-image-container {
      position: relative;
      background: linear-gradient(135deg, rgba(0, 119, 182, 0.1) 0%, rgba(0, 119, 182, 0.05) 100%);
      border-radius: 24px;
      padding: 40px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .hero-main-image {
      max-width: 100%;
      max-height: 400px;
      object-fit: contain;
      filter: drop-shadow(0 20px 40px rgba(0, 0, 0, 0.1));
    }

    .floating-card {
      position: absolute;
      background: white;
      padding: 16px 24px;
      border-radius: 12px;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
    }

    .floating-card-1 {
      bottom: -10px;
      left: -20px;
    }

    .floating-card-2 {
      top: 20px;
      right: -10px;
    }

    .floating-icon {
      width: 48px;
      height: 48px;
      background: var(--shop-primary-light);
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .category-card {
      background: white;
      border: 1px solid var(--shop-border);
      border-radius: 12px;
      padding: 24px;
      display: flex;
      align-items: center;
      gap: 16px;
      transition: all 0.3s ease;
      text-decoration: none;
    }

    .category-card:hover {
      border-color: var(--shop-primary);
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
      transform: translateY(-4px);
    }

    .category-icon {
      width: 64px;
      height: 64px;
      border-radius: 12px;
      background: var(--shop-primary-light);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .category-info h3 {
      font-size: 16px;
      font-weight: 600;
      color: var(--shop-secondary);
      margin: 0 0 4px 0;
    }

    .category-info p {
      font-size: 13px;
      color: var(--shop-text-muted);
      margin: 0;
    }

    /* Stats Bar */
    .stats-bar {
      background: var(--shop-surface);
      border-top: 1px solid var(--shop-border);
      border-bottom: 1px solid var(--shop-border);
    }

    .stats-container {
      padding: 40px 60px;
    }

    @media (max-width: 768px) {
      .stats-container {
        padding: 32px 28px;
      }
    }

    @media (max-width: 480px) {
      .stats-container {
        padding: 24px 24px;
      }
    }

    .stat-item {
      text-align: center;
      padding: 24px 16px;
    }

    .stat-number {
      font-size: 2rem;
      font-weight: 800;
      color: var(--shop-primary);
      line-height: 1;
      margin-bottom: 4px;
    }

    .stat-label {
      font-size: 13px;
      color: var(--shop-text-muted);
      font-weight: 500;
    }

    /* Feature Cards */
    .feature-card {
      background: white;
      border: 1px solid var(--shop-border);
      border-radius: 12px;
      padding: 24px;
      transition: all 0.3s ease;
    }

    .feature-card:hover {
      border-color: var(--shop-primary);
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
    }

    .feature-icon {
      width: 48px;
      height: 48px;
      border-radius: 10px;
      background: var(--shop-primary-light);
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 16px;
    }

    /* Testimonial Cards */
    .testimonial-card {
      background: white;
      border: 1px solid var(--shop-border);
      border-radius: 12px;
      padding: 28px;
      height: 100%;
      transition: all 0.3s ease;
    }

    .testimonial-card:hover {
      border-color: var(--shop-primary);
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
    }

    .star-rating {
      color: var(--shop-primary);
      font-size: 16px;
      margin-bottom: 16px;
    }

    /* FAQ */
    .faq-item {
      background: white;
      border: 1px solid var(--shop-border);
      border-radius: 12px;
      margin-bottom: 12px;
      overflow: hidden;
      transition: all 0.3s ease;
    }

    .faq-item:hover {
      border-color: var(--shop-primary);
    }

    .faq-question {
      padding: 20px 24px;
      cursor: pointer;
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-weight: 600;
      font-size: 1rem;
      color: var(--shop-secondary);
    }

    .faq-question:hover {
      color: var(--shop-primary);
    }

    .faq-answer {
      padding: 0 24px;
      color: var(--shop-text-muted);
      line-height: 1.7;
      max-height: 0;
      overflow: hidden;
      opacity: 0;
      transition: all 0.3s ease;
    }

    .faq-item.active .faq-answer {
      padding: 0 24px 20px 24px;
      max-height: 500px;
      opacity: 1;
    }

    .faq-item.active .faq-question i {
      transform: rotate(45deg);
    }

    /* CTA Section - Green Theme */
    .cta-full-section {
      background: linear-gradient(135deg, #0077b6 0%, #023e8a 100%);
    }

    .cta-box {
      position: relative;
      text-align: center;
      padding: 40px 20px;
      overflow: hidden;
    }

    .cta-content {
      position: relative;
      z-index: 2;
    }

    .cta-title {
      font-size: clamp(1.75rem, 4vw, 2.5rem);
      font-weight: 700;
      color: white;
      margin-bottom: 16px;
    }

    .cta-subtitle {
      font-size: 1rem;
      color: rgba(255, 255, 255, 0.85);
      max-width: 550px;
      margin: 0 auto 32px;
      line-height: 1.7;
    }

    .cta-form {
      display: flex;
      flex-direction: column;
      gap: 12px;
      justify-content: center;
      align-items: center;
      max-width: 500px;
      margin: 0 auto;
    }

    @media (min-width: 576px) {
      .cta-form {
        flex-direction: row;
      }
    }

    .cta-input {
      flex: 1;
      width: 100%;
      padding: 16px 24px;
      border: none;
      border-radius: 12px;
      font-size: 15px;
      background: white;
      color: #1e293b;
    }

    .cta-input::placeholder {
      color: #9ca3af;
    }

    .cta-button {
      padding: 16px 32px;
      background: #f59e0b;
      color: white;
      border: none;
      border-radius: 12px;
      font-weight: 600;
      font-size: 15px;
      cursor: pointer;
      transition: all 0.3s ease;
      white-space: nowrap;
    }

    .cta-button:hover {
      background: #d97706;
      transform: translateY(-2px);
    }

    .cta-privacy {
      margin-top: 20px;
      font-size: 13px;
      color: rgba(255, 255, 255, 0.7);
    }

    .cta-decoration {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      pointer-events: none;
    }

    .cta-circle {
      position: absolute;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.05);
    }

    .cta-circle-1 {
      width: 400px;
      height: 400px;
      top: -200px;
      right: -100px;
    }

    .cta-circle-2 {
      width: 300px;
      height: 300px;
      bottom: -150px;
      left: -50px;
    }

    /* About Us Section Styles */
    .about-image-grid {
      position: relative;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }

    .about-image-main {
      grid-column: span 2;
    }

    .about-image-secondary {
      grid-column: span 1;
    }

    .about-badge {
      position: absolute;
      bottom: 20px;
      right: 20px;
      background: #0077b6;
      color: white;
      padding: 20px 24px;
      border-radius: 12px;
      text-align: center;
      box-shadow: 0 8px 24px rgba(0, 119, 182, 0.3);
    }

    .about-badge-number {
      font-size: 2rem;
      font-weight: 800;
      line-height: 1;
    }

    .about-badge-text {
      font-size: 13px;
      font-weight: 500;
      line-height: 1.3;
      margin-top: 4px;
    }

    .about-stat {
      display: flex;
      gap: 16px;
      margin-bottom: 16px;
    }

    .about-stat-icon {
      width: 48px;
      height: 48px;
      border-radius: 10px;
      background: var(--shop-primary-light);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    /* Blog Cards */
    .blog-card {
      background: white;
      border: 1px solid var(--shop-border);
      border-radius: 12px;
      overflow: hidden;
      height: 100%;
      transition: all 0.3s ease;
    }

    .blog-card:hover {
      border-color: var(--shop-primary);
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
      transform: translateY(-4px);
    }

    .blog-image {
      width: 100%;
      height: 200px;
      object-fit: cover;
    }

    /* Quality Section */
    .quality-feature {
      display: flex;
      gap: 16px;
      margin-bottom: 24px;
    }

    .quality-icon {
      width: 48px;
      height: 48px;
      border-radius: 10px;
      background: var(--shop-primary-light);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    /* Utilities */
    .text-shop-primary { color: var(--shop-primary); }
    .bg-shop-surface { background: var(--shop-surface); }
    
    /* Feature Icons */
    .feature-icon-wrapper {
      width: 48px;
      height: 48px;
      background: var(--shop-primary-light);
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    /* Scroll Reveal Animation */
    .scroll-reveal {
      opacity: 0;
      transform: translateY(30px);
      transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .scroll-reveal.revealed {
      opacity: 1;
      transform: translateY(0);
    }

    /* ===== ENTERPRISE MOBILE-FIRST RESPONSIVE STYLES ===== */
    /* Based on 8px grid system with generous whitespace */
    /* Uses CSS tokens from mobile-fixes.css for consistency */
    
    /* Very small phones (320px) */
    @media (max-width: 360px) {
      .section-padding {
        padding: 36px 16px !important;
