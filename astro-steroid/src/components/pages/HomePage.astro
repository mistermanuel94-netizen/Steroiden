      color: rgba(255, 255, 255, 0.5);
      padding: 0 8px;
      font-size: 14px;
    }

    @keyframes ticker-scroll {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }

    .btn-shop-primary {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      background: var(--shop-primary);
      color: white;
      padding: 16px 32px;
      border-radius: 12px;
      font-weight: 600;
      font-size: 16px;
      text-decoration: none;
      transition: all 0.3s ease;
      border: none;
      cursor: pointer;
      min-height: 48px;
      box-sizing: border-box;
    }

    .btn-shop-primary:hover {
      background: var(--btn-primary-end);
      color: white;
      transform: translateY(-2px);
      box-shadow: 0 8px 20px rgba(26, 46, 90, 0.25);
    }

    .btn-shop-outline {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      background: transparent;
      color: var(--shop-secondary);
      padding: 16px 32px;
      border-radius: 12px;
      font-weight: 600;
      font-size: 16px;
      text-decoration: none;
      border: 2px solid var(--shop-border);
      transition: all 0.3s ease;
      cursor: pointer;
      min-height: 48px;
      box-sizing: border-box;
    }

    .btn-shop-outline:hover {
      border-color: var(--shop-primary);
      color: var(--shop-primary);
      background: var(--shop-primary-light);
    }

    /* Section Headers */
    .section-header {
      margin-bottom: 40px;
    }

    .section-label {
      font-size: 13px;
      font-weight: 600;
      color: var(--shop-primary);
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 8px;
    }

    .section-title {
      font-size: clamp(1.75rem, 4vw, 2.5rem);
      font-weight: 700;
      color: var(--shop-secondary);
      margin-bottom: 12px;
    }

    .section-desc {
      font-size: 1rem;
      color: var(--shop-text-muted);
      max-width: 600px;
    }

    /* Product Grid */
    .products-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 24px;
    }

    @media (max-width: 1200px) {
      .products-grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    @media (max-width: 992px) {
      .products-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 576px) {
      .products-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 12px;
      }
    }

    /* Category Cards - Shopcart Style */

    .category-card {
      background: #F5F0EB;
      border: 1px solid var(--shop-border);
      border-radius: 12px;
      padding: 24px;
      display: flex;
      align-items: center;
      gap: 16px;
      transition: all 0.3s ease;
      text-decoration: none;
    }

    .category-card:hover {
      border-color: var(--shop-primary);
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
      transform: translateY(-4px);
    }

    .category-icon {
      width: 64px;
      height: 64px;
      border-radius: 12px;
      background: var(--shop-primary-light);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .category-info h3 {
      font-size: 16px;
      font-weight: 600;
      color: var(--shop-secondary);
      margin: 0 0 4px 0;
    }

    .category-info p {
      font-size: 13px;
      color: var(--shop-text-muted);
      margin: 0;
    }

    /* Stats Bar */
    .stats-bar {
      background: var(--shop-surface);
      border-top: 1px solid var(--shop-border);
      border-bottom: 1px solid var(--shop-border);
    }

    .stats-container {
      padding: 40px 60px;
    }

    @media (max-width: 768px) {
      .stats-container {
        padding: 32px 28px;
      }
    }

    @media (max-width: 480px) {
      .stats-container {
        padding: 24px 24px;
      }
    }

    .stat-item {
      text-align: center;
      padding: 24px 16px;
    }

    .stat-number {
      font-size: 2rem;
      font-weight: 800;
      color: var(--shop-primary);
      line-height: 1;
      margin-bottom: 4px;
    }

    .stat-label {
      font-size: 13px;
      color: var(--shop-text-muted);
      font-weight: 500;
    }

    /* Feature Cards */
    .feature-card {
      background: #F5F0EB;
      border: 1px solid var(--shop-border);
      border-radius: 12px;
      padding: 24px;
      transition: all 0.3s ease;
    }

    .feature-card:hover {
      border-color: var(--shop-primary);
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
    }

    .feature-icon {
      width: 48px;
      height: 48px;
      border-radius: 10px;
      background: var(--shop-primary-light);
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 16px;
    }

    /* Testimonial Cards */
    .testimonial-card {
      background: #F5F0EB;
      border: 1px solid var(--shop-border);
      border-radius: 12px;
      padding: 28px;
      height: 100%;
      transition: all 0.3s ease;
    }

    .testimonial-card:hover {
      border-color: var(--shop-primary);
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
    }

    .star-rating {
      color: var(--shop-primary);
      font-size: 16px;
      margin-bottom: 16px;
    }

    /* FAQ */
    .faq-item {
      background: #F5F0EB;
      border: 1px solid var(--shop-border);
      border-radius: 12px;
      margin-bottom: 12px;
      overflow: hidden;
      transition: all 0.3s ease;
    }

    .faq-item:hover {
      border-color: var(--shop-primary);
    }

    .faq-question {
      padding: 20px 24px;
      cursor: pointer;
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-weight: 600;
      font-size: 1rem;
      color: var(--shop-secondary);
    }

    .faq-question:hover {
      color: var(--shop-primary);
    }

    .faq-answer {
      padding: 0 24px;
      color: var(--shop-text-muted);
      line-height: 1.7;
      max-height: 0;
      overflow: hidden;
      opacity: 0;
      transition: all 0.3s ease;
    }

    .faq-item.active .faq-answer {
      padding: 0 24px 20px 24px;
      max-height: 500px;
      opacity: 1;
    }

    .faq-item.active .faq-question i {
      transform: rotate(45deg);
    }

    /* CTA Section - Green Theme */
    .cta-full-section {
      background: linear-gradient(135deg, var(--btn-primary-start) 0%, var(--btn-primary-end) 100%);
    }

    .cta-box {
      position: relative;
      text-align: center;
      padding: 40px 20px;
      overflow: hidden;
    }

    .cta-content {
      position: relative;
      z-index: 2;
    }

    .cta-title {
      font-size: clamp(1.75rem, 4vw, 2.5rem);
      font-weight: 700;
      color: white;
      margin-bottom: 16px;
    }

    .cta-subtitle {
      font-size: 1rem;
      color: rgba(255, 255, 255, 0.85);
      max-width: 550px;
      margin: 0 auto 32px;
      line-height: 1.7;
    }

    .cta-form {
      display: flex;
      flex-direction: column;
      gap: 12px;
      justify-content: center;
      align-items: center;
      max-width: 500px;
      margin: 0 auto;
    }

    @media (min-width: 576px) {
      .cta-form {
        flex-direction: row;
      }
    }

    .cta-input {
      flex: 1;
      width: 100%;
      padding: 16px 24px;
      border: none;
      border-radius: 12px;
      font-size: 15px;
      background: white;
      color: #1A1A1A;
    }

    .cta-input::placeholder {
      color: #6B6B6B;
    }

    .cta-button {
      padding: 16px 32px;
      background: #C9A96E;
      color: white;
      border: none;
      border-radius: 12px;
      font-weight: 600;
      font-size: 15px;
      cursor: pointer;
      transition: all 0.3s ease;
      white-space: nowrap;
    }

    .cta-button:hover {
      background: #B8963E;
      transform: translateY(-2px);
    }

    .cta-privacy {
      margin-top: 20px;
      font-size: 13px;
      color: rgba(255, 255, 255, 0.7);
    }

    .cta-decoration {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      pointer-events: none;
    }

    .cta-circle {
      position: absolute;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.05);
    }

    .cta-circle-1 {
      width: 400px;
      height: 400px;
      top: -200px;
      right: -100px;
    }

    .cta-circle-2 {
      width: 300px;
      height: 300px;
      bottom: -150px;
      left: -50px;
    }

    /* About Us Section Styles */
    .about-image-grid {
      position: relative;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }

    .about-image-main {
      grid-column: span 2;
    }

    /* About Transformation Slider Styles */
    .about-slider {
      border-radius: 16px;
      overflow: hidden;
    }

    .about-slider .slide-item {
      outline: none;
    }

    .about-slider .slide-item img {
      width: 100%;
      height: auto;
      min-height: 400px;
      object-fit: cover;
    }

    .about-slider .slick-dots {
      bottom: 15px;
    }

    .about-slider .slick-dots li button:before {
      color: white;
      font-size: 10px;
      opacity: 0.7;
    }

    .about-slider .slick-dots li.slick-active button:before {
      color: white;
      opacity: 1;
    }

    .about-slider .slick-prev,
    .about-slider .slick-next {
      z-index: 10;
      width: 40px;
      height: 40px;
    }

    .about-slider .slick-prev {
      left: 15px;
    }

    .about-slider .slick-next {
      right: 15px;
    }

    .about-slider .slick-prev:before,
    .about-slider .slick-next:before {
      font-size: 24px;
      opacity: 0.9;
    }

    @media (max-width: 768px) {
      .about-slider .slide-item img {
        min-height: 300px;
      }
    }

    .about-image-secondary {
      grid-column: span 1;
    }

    .about-badge {
      position: absolute;
      bottom: 20px;
      right: 20px;
      background: var(--accent-primary);
      color: white;
      padding: 20px 24px;
      border-radius: 12px;
      text-align: center;
      box-shadow: 0 8px 24px rgba(26, 46, 90, 0.3);
    }

    .about-badge-number {
      font-size: 2rem;
      font-weight: 800;
      line-height: 1;
    }

    .about-badge-text {
      font-size: 13px;
      font-weight: 500;
      line-height: 1.3;
      margin-top: 4px;
    }

    .about-stat {
      display: flex;
      gap: 16px;
      margin-bottom: 16px;
    }

    .about-stat-icon {
      width: 48px;
      height: 48px;
      border-radius: 10px;
      background: var(--shop-primary-light);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    /* Blog Cards */
    .blog-card {
      background: #F5F0EB;
      border: 1px solid var(--shop-border);
      border-radius: 12px;
      overflow: hidden;
      height: 100%;
      transition: all 0.3s ease;
    }

    .blog-card:hover {
      border-color: var(--shop-primary);
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
      transform: translateY(-4px);
    }

    .blog-image {
      width: 100%;
      height: 200px;
      object-fit: cover;
    }

    /* Quality Section */
    .quality-feature {
      display: flex;
      gap: 16px;
      margin-bottom: 24px;
    }

    .quality-icon {
      width: 48px;
      height: 48px;
      border-radius: 10px;
      background: var(--shop-primary-light);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    /* Utilities */
    .text-shop-primary { color: var(--shop-primary); }
    .bg-shop-surface { background: var(--shop-surface); }

    /* Trust Bar */
    .trust-bar {
      background: #F5F0EB;
      border-bottom: 1px solid var(--shop-border);
    }

    .trust-bar-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0;
    }

    .trust-bar-item {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 24px 20px;
      border-right: 1px solid var(--shop-border);
      transition: all 0.3s ease;
    }

    .trust-bar-item:last-child {
      border-right: none;
    }

    .trust-bar-item:hover {
      background: var(--shop-primary-light);
    }

    .trust-bar-icon {
      width: 48px;
      height: 48px;
      border-radius: 12px;
      background: linear-gradient(135deg, var(--shop-primary), var(--btn-primary-end));
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .trust-bar-text h4 {
      font-size: 14px;
      font-weight: 700;
      color: var(--shop-secondary);
      margin: 0 0 2px 0;
    }

    .trust-bar-text p {
      font-size: 12px;
      color: var(--shop-text-muted);
      margin: 0;
    }

    @media (max-width: 992px) {
      .trust-bar-grid {
        grid-template-columns: repeat(2, 1fr);
      }
      .trust-bar-item:nth-child(2) {
        border-right: none;
      }
      .trust-bar-item:nth-child(1),
      .trust-bar-item:nth-child(2) {
        border-bottom: 1px solid var(--shop-border);
      }
    }

    @media (max-width: 576px) {
      .trust-bar-grid {
        grid-template-columns: 1fr 1fr;
      }
      .trust-bar-item {
        padding: 16px 14px;
        gap: 10px;
      }
      .trust-bar-icon {
        width: 40px;
        height: 40px;
      }
      .trust-bar-text h4 {
        font-size: 13px;
      }
      .trust-bar-text p {
        font-size: 11px;
      }
    }

    /* Why Choose Us Section */
    .why-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 24px;
    }

    .why-card {
      background: #F5F0EB;
      border: 1px solid var(--shop-border);
      border-radius: 16px;
      padding: 32px 24px;
      text-align: center;
      transition: all 0.3s ease;
      position: relative;
      overflow: hidden;
    }

    .why-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 3px;
      background: linear-gradient(90deg, var(--shop-primary), var(--btn-primary-end));
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    .why-card:hover {
      border-color: var(--shop-primary);
      box-shadow: 0 12px 32px rgba(0, 0, 0, 0.08);
      transform: translateY(-4px);
    }

    .why-card:hover::before {
      opacity: 1;
    }

    .why-card-icon {
      width: 64px;
      height: 64px;
      border-radius: 16px;
      background: var(--shop-primary-light);
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 20px;
    }

    .why-card h3 {
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--shop-secondary);
      margin: 0 0 10px 0;
    }

    .why-card p {
      font-size: 14px;
      color: var(--shop-text-muted);
      line-height: 1.65;
      margin: 0;
    }

    @media (max-width: 1200px) {
      .why-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 576px) {
      .why-grid {
        grid-template-columns: 1fr;
        gap: 16px;
      }
      .why-card {
        padding: 24px 20px;
        text-align: left;
        display: flex;
        gap: 16px;
        align-items: flex-start;
      }
      .why-card-icon {
        margin: 0;
        width: 52px;
        height: 52px;
        flex-shrink: 0;
      }
    }

    /* Category Grid - expanded to 6 */
    .category-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }

    @media (max-width: 1200px) {
      .category-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 576px) {
      .category-grid {
        grid-template-columns: 1fr;
      }
    }

    /* SEO Content Enhanced */
    .seo-content-section h2 {
      font-size: clamp(1.5rem, 3.5vw, 2rem);
    }

    .seo-content-section h3 {
      font-size: 1.15rem;
      font-weight: 600;
      color: var(--shop-secondary);
      margin-bottom: 10px;
    }

    .seo-content-section p {
      color: var(--shop-text-muted);
      line-height: 1.8;
      font-size: 15px;
    }

    .seo-card {
      background: #F5F0EB;
      border: 1px solid var(--shop-border);
      border-radius: 12px;
      padding: 28px;
      height: 100%;
      transition: all 0.3s ease;
    }

    .seo-card:hover {
      border-color: var(--shop-primary);
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
    }
    
    /* Feature Icons */
    .feature-icon-wrapper {
      width: 48px;
      height: 48px;
      background: var(--shop-primary-light);
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    /* Scroll Reveal Animation */
    .scroll-reveal {
      opacity: 0;
      transform: translateY(30px);
      transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .scroll-reveal.revealed {
      opacity: 1;
      transform: translateY(0);
    }

    /* ===== ENTERPRISE MOBILE-FIRST RESPONSIVE STYLES ===== */
    /* Based on 8px grid system with generous whitespace */
    /* Uses CSS tokens from mobile-fixes.css for consistency */
    
    /* Very small phones (320px) */
    @media (max-width: 360px) {
      .section-padding {
        padding: 36px 16px !important;
      }
    }
    
    /* Extra Small Mobile (up to 575px) */
    @media (max-width: 575px) {
      /* Section padding uses mobile-fixes.css tokens */
      
      /* Hero section - Generous spacing, no overflow */
      .hero-banner {
        min-height: auto;
      }

      .hero-banner .section-padding {
        padding-top: 32px;
        padding-bottom: 48px;
      }

      .hero-content {
        max-width: 100%;
      }

      .hero-trust-pills {
        gap: 8px;
        margin-bottom: 20px;
      }

      .hero-pill {
        font-size: 11px;
        padding: 6px 12px;
      }
      
      .hero-title {
        font-size: clamp(26px, 7.5vw, 42px) !important;
        line-height: 1.08;
        letter-spacing: -0.03em;
        margin-bottom: 16px;
        word-break: break-word;
        overflow-wrap: break-word;
      }

      /* Prevent title line break issues */
      .hero-title br {
        display: none;
      }

      .hero-description {
        font-size: 15px;
        margin-bottom: 28px;
        line-height: 1.65;
        max-width: 100%;
      }
      
      /* Buttons - Full width with proper touch targets */
      .btn-hero-primary,
      .btn-hero-outline,
      .btn-shop-primary,
      .btn-shop-outline {
        width: 100%;
        justify-content: center;
        padding: 16px 24px;
        font-size: 16px;
        min-height: 52px;
        border-radius: 14px;
        margin-bottom: 0;
        text-align: center;
      }

      /* CTA container - stack vertically with consistent gap */
      .hero-cta-group,
      .hero-content .d-flex.flex-wrap.gap-3,
      .d-flex.flex-wrap.gap-3 {
        gap: 12px !important;
        flex-direction: column;
        align-items: stretch;
        width: 100%;
      }

      .hero-social-proof {
        justify-content: center;
      }

      .hero-floating-shapes {
        display: none;
      }
      
      .btn-shop-primary:active,
      .btn-shop-outline:active,
      .btn-hero-primary:active,
      .btn-hero-outline:active {
        transform: scale(0.98);
        opacity: 0.92;
      }

      /* Ensure focus states are visible for accessibility */
      .btn-shop-primary:focus-visible,
      .btn-shop-outline:focus-visible,
      .btn-hero-primary:focus-visible,
      .btn-hero-outline:focus-visible {
        outline: 3px solid rgba(26, 46, 90, 0.4);
        outline-offset: 2px;
      }

      /* Hero navigation arrows hidden on mobile — already hidden by default */

      /* Ticker bar mobile */
      .ticker-item {
        font-size: 12px;
        padding: 0 12px;
      }

      /* Fix Bootstrap row negative margins causing overflow */
      .row {
        margin-left: 0;
        margin-right: 0;
      }

      .row > [class*="col-"] {
        padding-left: 6px;
        padding-right: 6px;
      }

      /* Hero row fix */
      .hero-banner .row {
        margin: 0;
      }
      
      /* Section headers - Clear hierarchy */
      .section-header {
        margin-bottom: 32px;
        text-align: center;
      }
      
      .section-label {
        font-size: 12px;
        letter-spacing: 1.5px;
        margin-bottom: 8px;
        display: block;
      }
      
      .section-title {
        font-size: clamp(20px, 5.5vw, 28px);
        line-height: 1.25;
        letter-spacing: -0.02em;
        margin-bottom: 12px;
      }
      
      .section-desc {
        font-size: 15px;
        line-height: 1.65;
        max-width: 100%;
      }
      
      /* Stats bar - Clean 2x2 grid with breathing room */
      .stats-bar {
        padding: 0 !important;
      }
      
      .stats-bar .inner-container {
        padding: 32px var(--m-pad-x, 24px) !important;
      }
      
      .stats-bar .row {
        margin: 0;
        gap: 0;
      }
      
      .stats-bar .row > [class*="col-"] {
        padding: 6px;
      }
      
      .stat-item {
