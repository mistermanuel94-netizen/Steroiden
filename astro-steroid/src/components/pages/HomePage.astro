    ru: ['товар', 'товаров'],
  };
  const [s, p] = labels[lang] || labels['en'];
  return `${count} ${count === 1 ? s : p}`;
};

// Count products per category for the current language
const langProducts = allProducts.filter(p => p.slug.startsWith(`${lang}/`));
const categoryCounts: Record<string, number> = {};
for (const p of langProducts) {
  const cat = p.data.category;
  categoryCounts[cat] = (categoryCounts[cat] || 0) + 1;
}

// Build the categories array — show top 12 categories sorted by defined order
const categories: Array<{ name: string; slug: string; localizedSlug: string; icon: string; desc: string; gradient: string; products: string }> = Object.entries(categoryCounts)
  .filter(([slug]) => categoryStyles[slug]) // only categories we have style for
  .sort((a, b) => (categoryStyles[a[0]]?.order || 99) - (categoryStyles[b[0]]?.order || 99))
  .slice(0, 12)
  .map(([slug, count]) => {
    const style = categoryStyles[slug];
    const i18n = categoryI18n[slug]?.[lang] || categoryI18n[slug]?.['en'];
    const catName = i18n?.name || slug.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
    return {
      name: catName,
      slug,
      localizedSlug: translateCategorySlug(slug, lang),
      icon: style.icon,
      desc: i18n?.desc || 'Quality pharmaceutical compounds',
      gradient: style.gradient,
      products: productLabel(count),
    };
  });

// Helper to get category URL with translated slug
const getCategoryUrl = (category: string) => {
  if (lang === 'en') {
    return `/steroids/${category}/`;
  }
  const translatedSlug = translateCategorySlug(category, lang);
  return `/${lang}/steroids/${translatedSlug}/`;
};

