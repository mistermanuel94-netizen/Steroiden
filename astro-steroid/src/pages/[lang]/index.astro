---
export const prerender = true;
import HomePage from '../../components/pages/HomePage.astro';
import { supportedLanguages, type SupportedLanguage } from '../../i18n/translations';

export async function getStaticPaths() {
  // Return all supported languages except the default one ('en')
  // as English is handled by the root index.astro
  return supportedLanguages
    .filter(lang => lang !== 'en')
    .map(lang => ({
      params: { lang },
      props: { lang }
    }));
}

const { lang } = Astro.params;
const pageLang = (lang && supportedLanguages.includes(lang as SupportedLanguage) ? lang : 'en') as SupportedLanguage;
---

<HomePage lang={pageLang} />
